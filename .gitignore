# ============================================
# AI Analytics Platform — .gitignore
# ============================================

# ---------- Environment & Secrets ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ---------- Google Cloud Credentials ----------
# CRITICAL: Never commit service account keys
credentials/
*.json
token.pickle
token.json
client_secret.json
!package.json
!package-lock.json
!tsconfig.json
!next.config.json
!tailwind.config.json
!postcss.config.json

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/
env/
ENV/

# ---------- Node.js ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Next.js ----------
.next/
out/

# ---------- IDE & OS ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------- Testing ----------
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.coverage
.coverage.*

# ---------- Build Artifacts ----------
*.log
logs/
